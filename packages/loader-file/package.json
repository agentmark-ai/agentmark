{
  "name": "@agentmark-ai/loader-file",
  "version": "0.1.5",
  "publishConfig": {
    "access": "public"
  },
  "description": "Filesystem-based loader for pre-built AgentMark prompts",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "license": "AGPL-3.0-or-later",
  "devDependencies": {
    "@types/node": "^22.8.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^4.1.8"
  },
  "scripts": {
    "build": "tsup",
    "build:package": "yarn build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "dependencies": {
    "@agentmark-ai/prompt-core": "*"
  }
}
