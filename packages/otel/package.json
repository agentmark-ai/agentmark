{
  "name": "@agentmark-ai/otel",
  "version": "0.2.0",
  "description": "Group AgentMark traces by session, user, and metadata via OpenTelemetry context. Works with the Vercel AI SDK (v7) and any OTel-instrumented spans.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@opentelemetry/exporter-trace-otlp-http": "^0.217.0"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-base": "^2.0.0"
  },
  "devDependencies": {
    "@agentmark-ai/eslint-config": "*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-base": "^2.2.0",
    "@opentelemetry/sdk-trace-node": "^2.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "license": "AGPL-3.0-or-later",
  "files": [
    "dist",
    "package.json",
    "README.md"
  ]
}
