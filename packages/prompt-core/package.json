{
  "name": "@agentmark-ai/prompt-core",
  "version": "0.8.2",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "webhook-runner": [
        "./dist/webhook-runner.d.ts"
      ],
      "test-utils": [
        "./dist/test-utils.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./test-utils": {
      "import": {
        "types": "./dist/test-utils.d.ts",
        "default": "./dist/test-utils.js"
      },
      "require": {
        "types": "./dist/test-utils.d.cts",
        "default": "./dist/test-utils.cjs"
      }
    },
    "./webhook-runner": {
      "import": {
        "types": "./dist/webhook-runner.d.ts",
        "default": "./dist/webhook-runner.js"
      },
      "require": {
        "types": "./dist/webhook-runner.d.cts",
        "default": "./dist/webhook-runner.cjs"
      }
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "build": "tsup && cpy ../../README.md ../../assets ./",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@agentmark-ai/conformance-vectors": "*",
    "@agentmark-ai/loader-file": "*",
    "@types/mdast": "^4.0.0",
    "@types/node": "^22.8.1",
    "@types/react": "^18",
    "cpy-cli": "^5.0.0",
    "dotenv": "^16.5.0",
    "react": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.2",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@agentmark-ai/templatedx": "0.4.1",
    "zod": "^3.23.8"
  },
  "files": [
    "dist/",
    "assets/",
    "README.md"
  ]
}
