{
  "name": "@agentmark-ai/fallback-adapter",
  "private": true,
  "version": "1.2.1",
  "description": "DEPRECATED — import createAgentMark from @agentmark-ai/prompt-core instead. This package is an unchanged re-export shim and will be removed in a future major.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
