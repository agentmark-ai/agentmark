      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "build": "tsup && cpy ../../README.md ../../logo.svg ./",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@agentmark-ai/loader-file": "*",
    "@agentmark-ai/prompt-core": "1.0.0",
    "@types/mdast": "^4.0.0",
    "@types/node": "^22.8.1",
    "@types/react": "^18",
    "cpy-cli": "^5.0.0",
    "react": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.2",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "@agentmark-ai/prompt-core": "*"
  },
  "files": [
    "dist/"
  ]
}
