{
  "name": "@agentmark-ai/ai-sdk-shared",
  "version": "0.4.4",
  "description": "Shared executor factory and model registry for the AgentMark Vercel AI SDK v4 and v5 adapters. Consumed by those adapters as a regular dependency.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@agentmark-ai/prompt-core": "*",
    "@types/node": "^22.8.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.2",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "@agentmark-ai/prompt-core": "*"
  },
  "files": [
    "dist/"
  ]
}
