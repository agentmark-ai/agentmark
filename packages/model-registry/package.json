{
  "name": "@agentmark-ai/model-registry",
  "version": "0.3.0",
  "description": "LLM model registry with provider metadata, pricing, and capabilities",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./pricing": {
      "types": "./dist/pricing.d.ts",
      "default": "./dist/pricing.js"
    },
    "./models.json": "./models.json",
    "./overrides.json": "./overrides.json",
    "./provider-labels.json": "./provider-labels.json",
    "./package.json": "./package.json"
  },
  "license": "AGPL-3.0-or-later",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "jest"
  },
  "files": [
    "dist",
    "models.json",
    "overrides.json",
    "provider-labels.json"
  ],
  "dependencies": {
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.13",
    "@types/node": "^20",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.8",
    "tsup": "^8.5.1",
    "typescript": "^5.5.3"
  }
}
