{
  "name": "@agentmark-ai/connect",
  "version": "0.1.0",
  "description": "WebSocket connect client for AgentMark — auto-connects your app to the platform",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "build:package": "yarn build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@agentmark-ai/prompt-core": "0.3.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.13",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^3.1.4"
  }
}
