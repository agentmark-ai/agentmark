    {
      "name": "full text row: tokens, evals, traceId all present",
      "args": {
        "input": { "userMessage": "What is 2+2?" },
        "expectedOutput": "4",
        "actualOutput": "4",
        "tokens": 11,
        "evals": [{ "name": "exact_match", "score": 1, "passed": true }],
        "traceId": "0af7651916cd43dd8448eb211c80319c",
        "runId": "run-123",
        "runName": "my-experiment"
      },
      "expected": {
        "type": "dataset",
        "result": {
          "input": { "userMessage": "What is 2+2?" },
          "expectedOutput": "4",
          "actualOutput": "4",
          "tokens": 11,
          "evals": [{ "name": "exact_match", "score": 1, "passed": true }]
        },
        "traceId": "0af7651916cd43dd8448eb211c80319c",
        "runId": "run-123",
        "runName": "my-experiment"
      }
