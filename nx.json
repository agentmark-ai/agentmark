{
  "$schema": "https://raw.githubusercontent.com/nrwl/nx/master/packages/nx/schemas/nx-schema.json",
  "release": {
    "versionPlans": {
      "ignorePatternsForPlanCheck": [
        "**/*.spec.ts",
        "**/*.test.ts",
        "**/*.spec.tsx",
        "**/*.test.tsx",
        "**/test/**",
        "**/tests/**",
        "**/__tests__/**",
        ".github/**",
        "yarn.lock",
        "package.json",
        "**/models.json",
        "**/vitest.config.ts"
      ]
    },
    "projectsRelationship": "independent",
    "groups": {
      "python": {
        "projects": ["agentmark-*"],
        "version": {
          "versionActions": "@nxlv/python/release/version-actions"
        }
      },
      "js": {
        "projects": ["packages/*", "!agentmark-*"]
      }
    },
    "changelog": {
      "projectChangelogs": {
        "file": "{projectRoot}/CHANGELOG.md",
        "renderOptions": {
          "authors": false
        }
      },
      "workspaceChangelog": false
    },
    "git": {
      "commit": false,
      "tag": false,
      "push": false
    },
    "version": {
      "fallbackCurrentVersionResolver": "disk"
    },
    "releaseTag": {
      "pattern": "{projectName}@{version}"
    }
  },
  "plugins": [
    {
      "plugin": "@nxlv/python",
      "options": {
        "packageManager": "uv"
      }
    },
    {
      "plugin": "@nx/js/typescript",
      "options": {
        "typecheck": {
          "targetName": "typecheck"
        },
        "build": {
          "targetName": "build",
          "configName": "tsconfig.lib.json",
          "buildDepsName": "build-deps",
          "watchDepsName": "watch-deps"
        }
      }
    }
  ],
  "analytics": false
}